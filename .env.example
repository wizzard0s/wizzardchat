# WizzardChat Configuration
# Copy this file to .env and fill in your values

# ── Database ─────────────────────────────────────────────────────────────────
# Async URL used by SQLAlchemy at runtime (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/wizzardfrw
# Sync URL used for any sync operations
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/wizzardfrw

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# IMPORTANT: Change this to a long random string in production
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=wizzardchat-dev-secret-key-change-in-production
ALGORITHM=HS256
# Token lifetime in minutes (480 = 8 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=WizzardChat
APP_PORT=8092
